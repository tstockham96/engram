{
  "name": "engram-sdk",
  "version": "0.1.0",
  "description": "Universal memory layer for AI agents. Remember, recall, consolidate.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "engram": "dist/cli.js",
    "engram-serve": "dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/server.ts",
    "mcp": "tsx src/mcp.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "llm",
    "rag",
    "consolidation",
    "engram"
  ],
  "author": "Thomas Stockham",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/tstockham96/engram"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^11.8.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
